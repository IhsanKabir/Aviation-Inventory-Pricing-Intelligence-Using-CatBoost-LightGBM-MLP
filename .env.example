AIRLINE_DB_URL=postgresql+psycopg2://postgres@localhost:5432/Playwright_API_Calling
AIRLINE_SOURCE_SWITCHES_FILE=config/source_switches.json
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Playwright_API_Calling
DB_USER=postgres
DB_PASSWORD=
BIGQUERY_PROJECT_ID=aeropulseintelligence
BIGQUERY_DATASET=aviation_intel
GOOGLE_APPLICATION_CREDENTIALS=
OPERATIONAL_COMPLETION_BUFFER_MINUTES=90
TRAINING_COMPLETION_BUFFER_MINUTES=120
ACCUMULATION_COMPLETION_BUFFER_MINUTES=90
TRAINING_PREDICTION_ML_MODELS=catboost,lightgbm
TRAINING_PREDICTION_DL_MODELS=mlp
TRAINING_SKIP_BIGQUERY_SYNC=0
DEEP_COMPLETION_BUFFER_MINUTES=120
DEEP_PREDICTION_ML_MODELS=catboost,lightgbm
DEEP_PREDICTION_DL_MODELS=mlp
DEEP_SKIP_BIGQUERY_SYNC=0
AIRLINE_OPS_WEBHOOK_URL=
PG_BIN_DIR=

# GoZayaan throttle. The OTA returns 429 with a 15-min cooldown when called
# too rapidly. 3.0s is the observed-safe default; lower at your own risk.
GOZAYAAN_INTER_QUERY_SLEEP=3.0
