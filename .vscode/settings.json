{
  "markdownlint.ignore": [
    "**/output/reports/**/*.md",
    "DAILY_PROGRESS_TRACKING.md"
  ],
  "markdownlint.config": {
    "MD013": {
      "line_length": 160,
      "code_blocks": false,
      "tables": false
    },
    "MD060": false
  },
  "cSpell.ignorePaths": [
    "output/reports/**/*.md",
    "DAILY_PROGRESS_TRACKING.md"
  ],
  "python.testing.unittestArgs": [
    "-v",
    "-s",
    ".",
    "-p",
    "*test.py"
  ],
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": true,
  "claudeCodeChat.permissions.yoloMode": false
}
